{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        cheshire/cheshire {:mvn/version "5.11.0"}
        org.replikativ/konserve {:mvn/version "0.9.345"}
        ;; canonical node handlers (org.replikativ.persistent-sorted-set.fressian)
        ;; shipped in 0.4.x.
        org.replikativ/persistent-sorted-set {:mvn/version "0.4.124"}
        is.simm/partial-cps {:mvn/version "0.1.58"}
        org.clojure/core.async {:mvn/version "1.6.681"}}

 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1"
                       :git/sha "dfb30dd"}
                      ;; datahike is an OPTIONAL adapter dep (the adapter only
                      ;; loads when datahike is present); provide it at test
                      ;; time so yggdrasil.adapters.datahike-test can exercise it.
                      org.replikativ/datahike {:mvn/version "0.8.1689"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}

  :dev {:extra-paths ["dev"]
        :extra-deps {nrepl/nrepl {:mvn/version "1.1.0"}}}

  ;; ClojureScript node test of the konserve-free catalog (bare cljs.main).
  :cljs-test {:extra-paths ["test"]
              :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
              :main-opts ["-m" "cljs.main" "-t" "node"
                          "-m" "yggdrasil.convergent.cljs-test"]}

  ;; shadow-cljs node-test (konserve-backed storage). shadow-cljs brings its own
  ;; current cljs (an old clojurescript pin is what breaks konserve's async+sync
  ;; macro on cljs). Released deps only.
  :shadow {:extra-paths ["test"]
           :extra-deps {thheller/shadow-cljs {:mvn/version "2.28.21"}}}

  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.6"}
                 slipset/deps-deploy {:mvn/version "0.2.0"}
                 io.github.borkdude/gh-release-artifact {:git/sha "b946558225a7839f6a0f644834e838e190dc2262"}
                 babashka/babashka.curl {:mvn/version "0.1.2"}
                 babashka/fs {:mvn/version "0.3.17"}
                 cheshire/cheshire {:mvn/version "5.11.0"}}
          :ns-default build}

  :format {:extra-deps {cljfmt/cljfmt {:mvn/version "0.9.2"}}
           :main-opts ["-m" "cljfmt.main" "check"]}

  :ffix {:extra-deps {cljfmt/cljfmt {:mvn/version "0.9.2"}}
         :main-opts ["-m" "cljfmt.main" "fix"]}}}
